// ============================================================
// TAIILRD — Prisma Schema
// SQLite by default for self-hosted simplicity.
// Swap provider to "postgresql" for hosted/cloud deployment.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------------
// USER PROFILE
// ------------------------------------------------------------

model Profile {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  location  String?
  website   String?
  linkedIn  String?
  github    String?
  headline  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  skills           Skill[]
  experiences      Experience[]
  projects         Project[]
  educations       Education[]
  certifications   Certification[]
  cvDocuments      CVDocument[]
  coverLetters     CoverLetterDocument[]
  jobApplications  JobApplication[]
  settings         UserSettings?
}

// ------------------------------------------------------------
// VAULT — PROFILE INGREDIENTS
// ------------------------------------------------------------

model Skill {
  id                String   @id @default(cuid())
  profileId         String
  name              String
  category          String   // SkillCategory enum as string
  level             String   // SkillLevel enum as string
  yearsOfExperience Float?
  tags              String   // JSON array stored as string
  notes             String?  // freeform markdown
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  profile           Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  experienceSkills  ExperienceSkill[]
  achievementSkills AchievementSkill[]
  projectSkills     ProjectSkill[]
  certificationSkills CertificationSkill[]

  @@index([profileId])
}

model Experience {
  id        String    @id @default(cuid())
  profileId String
  company   String
  role      String
  startDate DateTime
  endDate   DateTime?
  location  String?
  remote    Boolean   @default(false)
  summary   String    // 1–2 sentence prose overview
  tags      String    // JSON array
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  profile      Profile           @relation(fields: [profileId], references: [id], onDelete: Cascade)
  achievements Achievement[]
  skills       ExperienceSkill[]

  @@index([profileId])
}

model Achievement {
  id           String  @id @default(cuid())
  experienceId String
  description  String  // rich freeform prose
  impact       String? // quantifiable outcome
  tags         String  // JSON array

  experience Experience         @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  skills     AchievementSkill[]

  @@index([experienceId])
}

model Project {
  id          String    @id @default(cuid())
  profileId   String
  name        String
  description String    // freeform markdown prose
  url         String?
  repoUrl     String?
  startDate   DateTime?
  endDate     DateTime?
  status      String    @default("active") // active | completed | archived
  highlights  String    // JSON array of bullet points
  tags        String    // JSON array
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  profile Profile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skills  ProjectSkill[]

  @@index([profileId])
}

model Education {
  id            String    @id @default(cuid())
  profileId     String
  institution   String
  qualification String
  field         String?
  startDate     DateTime
  endDate       DateTime?
  grade         String?
  notes         String?   // freeform markdown
  tags          String    // JSON array
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model Certification {
  id            String    @id @default(cuid())
  profileId     String
  name          String
  issuer        String
  issueDate     DateTime
  expiryDate    DateTime?
  credentialUrl String?
  tags          String    // JSON array
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  profile Profile              @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skills  CertificationSkill[]

  @@index([profileId])
}

// Junction tables for skill relationships
model ExperienceSkill {
  experienceId String
  skillId      String
  experience   Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  skill        Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([experienceId, skillId])
}

model AchievementSkill {
  achievementId String
  skillId       String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  skill         Skill       @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([achievementId, skillId])
}

model ProjectSkill {
  projectId String
  skillId   String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  skill     Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([projectId, skillId])
}

model CertificationSkill {
  certificationId String
  skillId         String
  certification   Certification @relation(fields: [certificationId], references: [id], onDelete: Cascade)
  skill           Skill         @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([certificationId, skillId])
}

// ------------------------------------------------------------
// CV BUILDER
// ------------------------------------------------------------

model CVTemplate {
  id          String   @id @default(cuid())
  name        String
  region      String   @default("global")
  description String
  sections    String   // JSON — CVTemplateSection[]
  isDefault   Boolean  @default(false)
  isBuiltIn   Boolean  @default(false)
  createdAt   DateTime @default(now())

  cvDocuments CVDocument[]
}

model CVDocument {
  id               String   @id @default(cuid())
  profileId        String
  jobApplicationId String?
  templateId       String
  jobDescription   String?
  jobTitle         String?
  company          String?
  generatedContent String   // JSON — CVGeneratedContent
  status           String   @default("draft") // draft | final
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  profile        Profile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  template       CVTemplate      @relation(fields: [templateId], references: [id])
  jobApplication JobApplication? @relation(fields: [jobApplicationId], references: [id])
  coverLetters   CoverLetterDocument[]

  @@index([profileId])
}

// ------------------------------------------------------------
// COVER LETTER
// ------------------------------------------------------------

model CoverLetterDocument {
  id               String   @id @default(cuid())
  profileId        String
  jobApplicationId String?
  cvDocumentId     String?
  mode             String   // writer | coach
  jobDescription   String?
  jobTitle         String?
  company          String?
  sections         String   // JSON — CoverLetterSection[]
  status           String   @default("draft")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  profile        Profile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  jobApplication JobApplication? @relation(fields: [jobApplicationId], references: [id])
  cvDocument     CVDocument?     @relation(fields: [cvDocumentId], references: [id])

  @@index([profileId])
}

// ------------------------------------------------------------
// JOB TRACKER
// ------------------------------------------------------------

model JobApplication {
  id               String    @id @default(cuid())
  profileId        String
  jobTitle         String
  company          String
  jobDescription   String?
  jobUrl           String?
  location         String?
  remote           Boolean?
  salaryMin        Float?
  salaryMax        Float?
  currency         String?
  status           String    @default("saved")
  appliedAt        DateTime?
  notes            String?
  tags             String    // JSON array
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  profile      Profile               @relation(fields: [profileId], references: [id], onDelete: Cascade)
  contacts     ApplicationContact[]
  events       ApplicationEvent[]
  cvDocuments  CVDocument[]
  coverLetters CoverLetterDocument[]

  @@index([profileId])
  @@index([status])
}

model ApplicationContact {
  id            String  @id @default(cuid())
  applicationId String
  name          String
  role          String?
  email         String?
  linkedIn      String?
  notes         String?

  application JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

model ApplicationEvent {
  id            String    @id @default(cuid())
  applicationId String
  type          String    // note | interview | followup | offer | rejection | status_change
  title         String
  description   String?
  scheduledAt   DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())

  application JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

// ------------------------------------------------------------
// SETTINGS
// ------------------------------------------------------------

model UserSettings {
  id              String  @id @default(cuid())
  profileId       String  @unique
  llmProvider     String  @default("anthropic")
  llmModel        String  @default("claude-sonnet-4-20250514")
  llmApiKey       String? // encrypted at app layer
  llmBaseUrl      String? // for custom/ollama
  defaultTemplateId String?
  theme           String  @default("system")
  exportFormat    String  @default("pdf")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}
