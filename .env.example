# ── Database ──────────────────────────────────────────────────
# Local dev default (matches docker-compose.yml)
DATABASE_URL="postgresql://taiilrd:taiilrd@localhost:5435/taiilrd"

# ── Auth ──────────────────────────────────────────────────────
BETTER_AUTH_SECRET=""          # openssl rand -base64 32
BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_TRUSTED_ORIGINS="http://localhost:3000"

# ── Encryption ────────────────────────────────────────────────
ENCRYPTION_KEY="dev-encryption-key-32-bytes-long!!"   # must be exactly 32 bytes in prod

# ── Chromium for SPA rendering (Puppeteer) ────────────────────
# In development, puppeteer devDep provides the binary automatically.
# In production (Vercel), leave both blank to download from Sparticuz CDN, or set
# CHROMIUM_EXECUTABLE_PATH to a pre-cached binary path.
CHROMIUM_EXECUTABLE_PATH=
CHROMIUM_PACK_URL=

# ── Email (Resend) ────────────────────────────────────────────
# Optional — only needed if you want password-reset / magic-link emails
RESEND_API_KEY=""
SENDER_EMAIL=""                # e.g. no-reply@yourdomain.com

# ── Social login ──────────────────────────────────────────────
# Each provider only activates when BOTH its _CLIENT_ID and _CLIENT_SECRET are set.
# Leave blank to disable a provider entirely.

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""

TWITTER_CLIENT_ID=""
TWITTER_CLIENT_SECRET=""

# ── GitHub (issue sync, optional) ─────────────────────────────
GITHUB_ISSUE_TOKEN=""

# ── Vercel (auto-set in Vercel deployments, not needed locally) ──
# VERCEL_URL=
# VERCEL_PROJECT_PRODUCTION_URL=
