// ------------------------------------------------------------
// SETTINGS
// ------------------------------------------------------------

model UserSettings {
  id                    String    @id @default(cuid())
  profileId             String    @unique
  llmProvider           String    @default("anthropic")
  llmModel              String    @default("claude-sonnet-4-5-20251001")
  llmApiKey             String?
  llmBaseUrl            String?
  defaultTemplateId     String?
  theme                 String    @default("system")
  exportFormat          String    @default("pdf")
  /// Gentle, optional onboarding context for future LLM features.
  /// Shape is documented in src/modules/onboarding/schema.ts and kept
  /// separate from the detailed Career Profile/CV ingredient models.
  onboardingContext     Json?
  onboardingCompletedAt DateTime?
  onboardingSkippedAt   DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}
