// ------------------------------------------------------------
// SETTINGS
// ------------------------------------------------------------

model UserSettings {
  id                    String    @id @default(cuid())
  profileId             String    @unique
  llmProvider           String    @default("anthropic")
  llmModel              String    @default("claude-sonnet-4-5-20251001")
  chatModel             String?
  llmApiKey             String?
  llmBaseUrl            String?
  /// Cached model list from the provider. Shape: { id: string; name: string }[]
  availableModels       Json?
  defaultTemplateId     String?
  theme                 String    @default("system")
  exportFormat          String    @default("pdf")
  /// Gentle, optional onboarding context for future LLM features.
  /// Shape is documented in src/modules/onboarding/schema.ts and kept
  /// separate from the detailed Career Profile/CV ingredient models.
  onboardingContext     Json?
  /// Universal search criteria for Job Hunt page. Shape: JobHuntSearchCriteria in src/modules/job-hunt/board-sources/schema.ts
  jobHuntSearch     Json?
  /// Encrypted API keys for paid job board sources. Shape: { jsearch?: string }
  jobBoardApiKeys   Json?
  writingBrief          String?
  onboardingCompletedAt DateTime?
  onboardingSkippedAt   DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}
